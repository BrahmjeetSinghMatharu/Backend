<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test App</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white px-20 py-10 flex flex-col gap-8">
        <h3>You can update your post.</h3>
        <form action="/update/<%= post._id %>" method="post">
            <textarea placeholder="What's on your mind ?" class="w-full h-40 bg-zinc-800 text-white p-4 rounded-md block" name="content" id="content"><%= post.content %></textarea>
            <input class="px-5 py-2 rounded-md bg-blue-600 text-zinc-400 mt-4 block" type="submit" value="Update Post">
        </form>
    </div>

</body>
</html>