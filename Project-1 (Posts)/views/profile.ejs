<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test App</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white px-20 py-10 flex flex-col gap-8">
        <!-- Navigation Bar -->
        <div class="w-full flex justify-end">
            <a href="/logout" class="text-white-400 hover:underline bg-red-500 px-4 py-2 rounded-md">Logout</a>
        </div>
        <!-- Form to create a new post -->
        <div class="flex items-center gap-4"> 
            <div class="w-10 h-10 rounded-md overflow-hidden">
                <img src="/images/uploads/<%= user.profilepic %>" alt="Profile Picture" class="w-full h-full object-cover rounded-md">
            </div>
            <h1 class="text-2xl font-bold">Hello <%= user.name %> 🚀</h1>
        </div>

        <h3>You can create a new post.</h3>
        <form action="/post" method="post">
            <textarea placeholder="What's on your mind ?" class="w-full h-40 bg-zinc-800 text-white p-4 rounded-md block" name="content" id="content"></textarea>
            <input class="px-5 py-2 rounded-md bg-blue-600 text-zinc-400 mt-4 block" type="submit" value="Create Post">
        </form>
        <!-- User's Posts -->
        <div class="posts mt-6">
            <h3 class="text-zinc-400">Your Posts</h3>
            <div class="postContainer flex flex-wrap gap-4 mt-4">
                <% user.posts.reverse().forEach(function(post) { %>
                <div class="post w-1/3 p-4 border-2 border-zinc-800 mt-10 rounded-md bg-zinc-800">
                    <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
                    <p class="text-sm tracking-tight"><%= post.content %></p>
                    <small class="text-zinc-500"><%= post.likes.length %> likes</small>
                    <div class="btns flex">
                        <a href="/like/<%= post._id %>" class="px-3 py-1 bg-sky-700 text-white rounded-md mt-4"><%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %></a>
                        <a href="/edit/<%= post._id %>" class="px-3 py-1 bg-sky-900 text-white rounded-md mt-4 ml-4">Edit</a>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>

</body>
</html>