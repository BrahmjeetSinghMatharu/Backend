<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test App</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white px-20 py-10 flex flex-col gap-10">
        <h1 class="text-2xl font-bold mb-4">Upload Profile Picture</h1>
        <form class="flex flex-col gap-4 justify-center" action="/upload" method="post" enctype="multipart/form-data">
            <input type="file" name="image" class="px-3 py-2 rounded-md outline-none bg-zinc-600 border-zinc-100 ">
            <input class="px-5 py-2 rounded-md bg-blue-600 text-white rounded-md" type="submit" value="Upload File">
        </form>
    </div>
</body>
</html>