<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test App</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white px-20 py-10 flex flex-col gap-10">
        <h1 class="text-2xl font-bold mb-4">Login User</h1>
        <form class="flex flex-col gap-4 justify-center" action="/login" method="post">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-zinc-800" type="email" name="email" placeholder="Email">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-zinc-800" type="password" name="password" placeholder="password">
            <input class="px-5 py-2 rounded-md bg-blue-600 text-white rounded-md" type="submit" value="Login User">
        </form>
    </div>
</body>
</html>