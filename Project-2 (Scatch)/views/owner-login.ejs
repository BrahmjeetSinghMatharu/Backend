<%- include('./partials/header') %>

<main class="mx-auto flex min-h-[calc(100vh-80px)] max-w-7xl items-center px-4 py-8 sm:px-6 lg:px-8">
    <section class="w-full max-w-xl rounded-3xl border border-ink/10 bg-white p-8 shadow-soft">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-steel">Restricted Area</p>
        <h1 class="mt-2 font-display text-4xl font-bold">Owner Access</h1>
        <p class="mt-2 text-sm text-ink/70">Use your owner credentials to manage products.</p>

        <form action="/owners/create" method="post" class="mt-8 space-y-3">
            <input class="w-full rounded-xl border border-ink/15 bg-sand px-4 py-3 outline-none focus:border-ink" type="email" placeholder="Email" name="email" required>
            <input class="w-full rounded-xl border border-ink/15 bg-sand px-4 py-3 outline-none focus:border-ink" type="password" placeholder="Password" name="password" required>
            <button class="w-full rounded-xl bg-ink px-4 py-3 font-semibold text-white transition hover:bg-coral">Login</button>
        </form>
    </section>
</main>

<%- include('./partials/footer') %>
