<%- include('./partials/header') %>

<main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-steel">Control Panel</p>
            <h1 class="font-display text-4xl font-bold">Admin Dashboard</h1>
        </div>
        <a class="rounded-xl bg-ink px-4 py-2.5 font-semibold text-white transition hover:bg-coral" href="/owners/admin">Create Product</a>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        <article class="rounded-3xl border border-ink/10 bg-white p-5 shadow-soft">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-coral/15 text-coral"><i class="ri-shopping-bag-line"></i></div>
            <h3 class="font-display text-xl font-semibold">Product Space</h3>
            <p class="mt-2 text-sm text-ink/70">Manage catalog items, prices, color themes, and product images.</p>
        </article>
        <article class="rounded-3xl border border-ink/10 bg-white p-5 shadow-soft">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-mint/20 text-ink"><i class="ri-line-chart-line"></i></div>
            <h3 class="font-display text-xl font-semibold">Sales Pulse</h3>
            <p class="mt-2 text-sm text-ink/70">Track store metrics and conversion performance in one place.</p>
        </article>
        <article class="rounded-3xl border border-ink/10 bg-white p-5 shadow-soft">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-ink/10 text-ink"><i class="ri-user-settings-line"></i></div>
            <h3 class="font-display text-xl font-semibold">Access Control</h3>
            <p class="mt-2 text-sm text-ink/70">Owner-only section for creating and maintaining product inventory.</p>
        </article>
    </div>
</main>

<%- include('./partials/footer') %>
