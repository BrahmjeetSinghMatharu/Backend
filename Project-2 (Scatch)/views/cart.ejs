<%- include('./partials/header') %>

<% const cartItems = user && Array.isArray(user.cart) ? user.cart : []; %>
<% const firstItem = cartItems.length ? cartItems[0] : null; %>

<main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-steel">Checkout</p>
        <h1 class="font-display text-4xl font-bold">Your Cart</h1>
    </div>

    <% if(!firstItem){ %>
        <div class="rounded-3xl border border-dashed border-ink/20 bg-white/70 p-12 text-center">
            <h2 class="font-display text-2xl font-semibold">Your cart is empty</h2>
            <p class="mt-2 text-sm text-ink/70">Add products from shop to see billing details here.</p>
            <a href="/shop" class="mt-5 inline-block rounded-xl bg-ink px-5 py-2.5 font-semibold text-white transition hover:bg-coral">Continue Shopping</a>
        </div>
    <% } else { %>
        <% const imageSrc = firstItem.image ? ('data:image/jpeg;base64,' + firstItem.image.toString('base64')) : '/images/1bag.png'; %>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-5">
            <section class="overflow-hidden rounded-3xl border border-ink/10 bg-white shadow-soft lg:col-span-2">
                <div class="flex h-80 items-center justify-center" style="background-color: <%= firstItem.bgcolor || '#f3f4f6' %>;"><img class="h-64 w-auto object-contain" src="<%= imageSrc %>" alt="<%= firstItem.name %>"></div>
                <div class="p-5" style="background-color: <%= firstItem.panelColor || '#111827' %>; color: <%= firstItem.textColor || '#ffffff' %>;">
                    <div class="flex items-center justify-between">
                        <h3 class="font-display text-2xl font-semibold"><%= firstItem.name %></h3>
                        <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-ink">QTY 1</span>
                    </div>
                    <p class="mt-3 text-sm opacity-90">Smart utility carry bag built for daily hustle.</p>
                </div>
                <div class="flex items-center justify-between bg-ink px-5 py-4 text-white">
                    <span class="font-medium">Net Total</span>
                    <span class="font-display text-2xl font-bold">₹ <%= bill %></span>
                </div>
            </section>

            <section class="rounded-3xl border border-ink/10 bg-white p-6 shadow-soft lg:col-span-3">
                <h3 class="font-display text-2xl font-semibold">Price Breakdown</h3>
                <div class="mt-6 space-y-4 text-sm">
                    <div class="flex items-center justify-between rounded-xl bg-sand px-4 py-3">
                        <span class="text-ink/70">Total MRP</span>
                        <span class="font-semibold">₹ <%= firstItem.price %></span>
                    </div>
                    <div class="flex items-center justify-between rounded-xl bg-sand px-4 py-3">
                        <span class="text-ink/70">Discount on MRP</span>
                        <span class="font-semibold text-green-700">- ₹ <%= Number(firstItem.discount) %></span>
                    </div>
                    <div class="flex items-center justify-between rounded-xl bg-sand px-4 py-3">
                        <span class="text-ink/70">Platform Fee</span>
                        <span class="font-semibold">₹ 20</span>
                    </div>
                    <div class="flex items-center justify-between rounded-xl bg-sand px-4 py-3">
                        <span class="text-ink/70">Shipping Fee</span>
                        <span class="font-semibold text-green-700">FREE</span>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-between border-t border-ink/10 pt-5">
                    <h4 class="font-display text-2xl font-bold">Total Amount</h4>
                    <h4 class="font-display text-3xl font-bold text-coral">₹ <%= bill %></h4>
                </div>

                <button class="mt-8 w-full rounded-xl bg-ink px-4 py-3 font-semibold text-white transition hover:bg-coral">Proceed to Checkout</button>
            </section>
        </div>
    <% } %>
</main>

<%- include('./partials/footer') %>
